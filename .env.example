# Stratos BEP -- Production Environment Variables
# Copy to .env and fill in real values: cp .env.example .env
# NEVER commit .env to version control

# ── Django ──
SECRET_KEY=CHANGE-ME-run-python-c-"from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=False
ALLOWED_HOSTS=YOUR_SERVER_IP,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://YOUR_SERVER_IP
HTTPS_ENABLED=false
DJANGO_SETTINGS_MODULE=stratos_server.settings.prod

# ── Database (PostgreSQL) ──
POSTGRES_DB=stratos_db
POSTGRES_USER=stratos_user
POSTGRES_PASSWORD=CHANGE-ME-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://stratos_user:CHANGE-ME-strong-password@postgres:5432/stratos_db

# ── Redis + Celery ──
REDIS_URL=redis://redis:6379/0

# ── Gmail API ──
# Credentials are managed via the Settings UI (Admin > Settings > Gmail Integration)
# These paths tell Django where to store the files inside the container
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json
GMAIL_TOKEN_PATH=credentials/gmail_token.json

# ── API Keys ──
# API keys are now managed via the Settings UI (Admin > Settings > API Keys)
# The fields below are kept for backward compatibility / .env fallback only
# VIRUSTOTAL_API_KEY=
# ABUSEIPDB_API_KEY=
